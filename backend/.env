# ==========================================
# 模板文件 — 可安全提交 Git
# ==========================================
# 使用方法: 复制此文件到 venv/.env 并填入真实 Key
#   cp .env.example venv/.env
#   nano venv/.env
# ==========================================

# DeepSeek API Key（从 platform.deepseek.com 获取）
LLM_API_KEY=your_deepseek_api_key_here
LLM_MODEL_ID=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# 高德地图 Web 服务 Key（从 console.amap.com 获取，选"Web服务"类型）
AMAP_API_KEY=your_amap_web_service_key_here

# 服务配置
HOST=0.0.0.0
PORT=8000
